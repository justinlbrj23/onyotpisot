{
  "name": "onyot-ai-scrapers",
  "version": "1.0.0",
  "description": "Property Appraiser Scraper Suite with OCR and Google Sheets automation",
  "main": "organizer_headers_tssf.js",
  "type": "module",
  "scripts": {
    "start": "node organizer_headers_tssf.js",
    "fetch:auctions": "node dac_scraper.cjs",
    "fetch:titleSearch": "node titleSearch.cjs",
    "ocr": "node ocr_pipeline.js",
    "ocr:img": "cross-env OCR_POLARITY=light-on-dark OCR_PSM=7 OCR_WHITELIST=ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789 node ocr_pipeline.js ./sample.png",
    "ocr:img:dark": "cross-env OCR_POLARITY=dark-on-light node ocr_pipeline.js ./sample.png",
    "ocr:img:auto": "cross-env OCR_POLARITY=auto node ocr_pipeline.js ./sample.png",
    "ocr:pdf": "cross-env OCR_DPI=400 OCR_MAX_PAR=6 node ocr_pipeline.js ./sample.pdf",
    "ocr:code6": "cross-env OCR_PSM=7 OCR_WHITELIST=ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789 OCR_CODE_LEN=6 node ocr_pipeline.js ./sample.png",
    "test": "echo \"No tests defined\" && exit 0",
    "lint": "eslint ."
  },
  "dependencies": {
    "@google-cloud/vision": "^4.3.2",
    "axios": "^1.6.0",
    "chromedriver": "^140.0.4",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "googleapis": "^159.0.0",
    "puppeteer": "^22.0.0",
    "selenium-webdriver": "^4.23.0",
    "xlsx": "^0.18.5",
    "puppeteer-real-browser": "^1.3.18",
    "puppeteer-extra": "^3.3.6",
    "pdfjs-dist": "^3.6.172",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.15.0",
    "pdf-parse": "^1.1.1",
    "he": "^1.2.0",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "uuidv4": "^6.2.13",
    "node-fetch": "^2.7.0",
    "p-limit": "^7.2.0",
    "cheerio": "^1.1.2"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "Justin Otment",
  "license": "ISC"
}
